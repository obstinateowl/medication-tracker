# MariaDB
# Use 127.0.0.1 when MariaDB runs on the same machine as this app.
# Home Assistant app: see DOCS.md — MariaDB add-on usually uses core-mariadb, not localhost.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=medtracker
DB_PASSWORD=change_me
DB_NAME=medication_tracker

# Server
PORT=8099
HOST=0.0.0.0

# Production standalone — serve built React UI from Express
SERVE_STATIC=true
NODE_ENV=production

# Dev only — comma-separated CORS origins (not needed for HA Ingress or standalone same-origin)
CLIENT_ORIGIN=http://localhost:5173

# MQTT (Home Assistant / Mosquitto) — optional for standalone testing
MQTT_ENABLED=false
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=medication_tracker
