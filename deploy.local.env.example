# Copy to deploy.local.env and fill in your values (do not commit credentials in the .example file).
# deploy.local.env is gitignored — never commit credentials.

# --- SMB destination (Home Assistant addons share) ---
DEPLOY_SMB_URL=smb://192.168.68.78/addons/
DEPLOY_SMB_USER=homeassistant
DEPLOY_SMB_PASSWORD=change_me

# Optional: skip auto-mount and rsync here instead (e.g. already mounted via file manager)
# DEPLOY_MOUNT=/run/user/1000/gvfs/smb-share:server=192.168.68.78,share=addons

# --- MariaDB (written into packaged config.yaml defaults) ---
DB_HOST=core-mariadb
DB_PORT=3306
DB_USER=medtracker
DB_PASSWORD=change_me
DB_NAME=medication_tracker

# --- MQTT / Mosquitto ---
MQTT_ENABLED=true
MQTT_HOST=core-mosquitto
MQTT_PORT=1883
MQTT_USER=med_tracker
MQTT_PASSWORD=change_me
MQTT_TOPIC_PREFIX=medication_tracker
